{
  "name": "itops-kiro-harness",
  "version": "1.5.1",
  "private": true,
  "type": "module",
  "description": "Read-only, multi-agent ITOps investigation harness for Kiro CLI v3",
  "engines": {
    "node": "^22.12.0 || ^24.0.0"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:protocol": "vitest run tests/mcp-contract.test.ts tests/mcp-http-integrations.test.ts",
    "validate": "node dist/cli/validate-config.js",
    "validate:runtime": "node dist/cli/validate-config.js --runtime",
    "validate:static": "node scripts/qa-static.mjs",
    "health": "node dist/cli/healthcheck.js",
    "configure:kiro-permissions": "node dist/cli/configure-kiro-permissions.js",
    "verify": "npm run build && npm test && npm run validate && npm run validate:static"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "mongodb": "7.5.0",
    "mssql": "12.7.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "optionalDependencies": {
    "msnodesqlv8": "5.2.3"
  },
  "overrides": {
    "@hono/node-server": "2.0.11"
  },
  "devDependencies": {
    "@types/mssql": "12.3.0",
    "@types/node": "24.3.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
