# Copy this file to config\itops.env, fill values, and keep that file out of source control.
# Use read-only service identities only. Do not add quotes unless the value itself requires them.

# Harness
ITOPS_REPORT_DIR=reports
ITOPS_ARTIFACT_DIR=artifacts/splunk
ITOPS_AUDIT_LOG=audit/mcp-audit.jsonl
ITOPS_HOOK_AUDIT_LOG=audit/kiro-hook-audit.jsonl
ITOPS_MAX_RESULT_BYTES=1000000
ITOPS_MAX_HTTP_RESPONSE_BYTES=5000000
ITOPS_HTTP_TIMEOUT_MS=30000
ITOPS_REDACT_KEYS=access_token,refresh_token,client_secret,user_email,phone,address
# For private enterprise CAs, set a PEM bundle path. Never disable certificate validation.
NODE_EXTRA_CA_CERTS=

# Enable or disable integrations independently
ITOPS_ENABLE_ATLASSIAN=true
ITOPS_ENABLE_SPLUNK=true
ITOPS_ENABLE_SQLSERVER=true
ITOPS_ENABLE_MONGODB=true
ITOPS_ENABLE_DYNATRACE=true
ITOPS_ENABLE_ARGOCD=true
ITOPS_ENABLE_SOURCE_CODE=true
ITOPS_ENABLE_BITBUCKET=true
ITOPS_ENABLE_GITLAB=true

# Jira and Confluence: Cloud basic auth uses email + API token.
# For Data Center PAT, set ATLASSIAN_AUTH_MODE=bearer and adjust paths if necessary.
ATLASSIAN_BASE_URL=https://YOUR_SITE.atlassian.net
ATLASSIAN_AUTH_MODE=basic
ATLASSIAN_EMAIL=CHANGE_ME
ATLASSIAN_API_TOKEN=CHANGE_ME
ATLASSIAN_JIRA_SEARCH_PATH=/rest/api/3/search/jql
ATLASSIAN_CONFLUENCE_SEARCH_PATH=/wiki/rest/api/search
ATLASSIAN_MAX_RESULTS=100

# Splunk REST endpoint. Kerberos mode uses the current Windows logon through
# curl.exe/SSPI and stores no Splunk password or token. The endpoint must
# advertise HTTP Negotiate (often through an enterprise reverse proxy).
SPLUNK_AUTH_MODE=kerberos
SPLUNK_BASE_URL=https://YOUR_SPLUNK_HOST:8089
SPLUNK_CURL_PATH=curl.exe
SPLUNK_CURL_CA_BUNDLE=
# Token fallback only when SPLUNK_AUTH_MODE=token.
SPLUNK_TOKEN=
SPLUNK_AUTH_SCHEME=Bearer
SPLUNK_EXPORT_PATH=/services/search/v2/jobs/export
SPLUNK_MAX_RESULTS=500
SPLUNK_SEARCH_TIMEOUT_MS=60000

# Named SQL Server Availability Group listener / readable-secondary connections.
# Profile names must use lowercase letters, digits, and underscores. Every profile
# gets a separate pool and exact-database replica proof. Windows mode uses the
# identity running Kiro; no Windows password is stored.
SQLSERVER_CONNECTIONS=mobile,orders
SQLSERVER_ODBC_DRIVER=ODBC Driver 18 for SQL Server
SQLSERVER_ENCRYPT=true
SQLSERVER_TRUST_SERVER_CERTIFICATE=false
SQLSERVER_CONNECT_TIMEOUT_MS=15000
SQLSERVER_QUERY_TIMEOUT_MS=30000
SQLSERVER_MAX_ROWS=500
SQLSERVER_POOL_MAX=4

# First SQL connection: Windows integrated authentication.
SQLSERVER_MOBILE_AUTH_MODE=windows
SQLSERVER_MOBILE_HOST=YOUR_MOBILE_AG_LISTENER
SQLSERVER_MOBILE_PORT=1433
SQLSERVER_MOBILE_DATABASE=YOUR_MOBILE_DATABASE
SQLSERVER_MOBILE_MULTI_SUBNET_FAILOVER=true

# Second SQL connection. Set AUTH_MODE=sql only for a dedicated read-only login.
SQLSERVER_ORDERS_AUTH_MODE=windows
SQLSERVER_ORDERS_HOST=YOUR_ORDERS_AG_LISTENER
SQLSERVER_ORDERS_PORT=1433
SQLSERVER_ORDERS_DATABASE=YOUR_ORDERS_DATABASE
SQLSERVER_ORDERS_MULTI_SUBNET_FAILOVER=true
SQLSERVER_ORDERS_USERNAME=
SQLSERVER_ORDERS_PASSWORD=

# Named MongoDB/Amazon DocumentDB URI connections. Each URI can expose every
# non-system database visible to its read-only identity. DATABASE_ALLOWLIST=*
# means all such databases; replace it with comma-separated names/patterns to
# narrow access. System databases admin, config, and local are always blocked.
MONGODB_CONNECTIONS=mobile,archive
MONGODB_CONNECT_TIMEOUT_MS=15000
MONGODB_QUERY_TIMEOUT_MS=30000
MONGODB_MAX_DOCUMENTS=500
MONGODB_POOL_MAX=4

# MongoDB URI example:
# mongodb://readonly-user:password@host:27017/?authSource=admin&readPreference=secondaryPreferred
MONGODB_MOBILE_MODE=mongodb
MONGODB_MOBILE_URI=CHANGE_ME
MONGODB_MOBILE_TLS_CA_FILE=
MONGODB_MOBILE_READ_PREFERENCE=secondaryPreferred
MONGODB_MOBILE_DATABASE_ALLOWLIST=*
MONGODB_MOBILE_COLLECTION_ALLOWLIST=*

# Amazon DocumentDB URI example:
# mongodb://readonly-user:password@docdb.cluster:27017/?tls=true&replicaSet=rs0&readPreference=secondaryPreferred&retryWrites=false
MONGODB_ARCHIVE_MODE=documentdb
MONGODB_ARCHIVE_URI=CHANGE_ME
MONGODB_ARCHIVE_TLS_CA_FILE=C:\certificates\global-bundle.pem
MONGODB_ARCHIVE_READ_PREFERENCE=secondaryPreferred
MONGODB_ARCHIVE_DATABASE_ALLOWLIST=*
MONGODB_ARCHIVE_COLLECTION_ALLOWLIST=*

# Dynatrace official remote MCP. Kiro opens the browser and Dynatrace SSO can
# federate to Microsoft Entra ID. Dynatrace still requires a confidential OAuth
# client because a browser session cookie is not an API credential.
DYNATRACE_MCP_URL=https://YOUR_ENV_ID.apps.dynatrace.com/platform-reserved/mcp-gateway/v0.1/servers/dynatrace-mcp/mcp
DYNATRACE_OAUTH_CLIENT_ID=CHANGE_ME
DYNATRACE_OAUTH_CLIENT_SECRET=CHANGE_ME
DYNATRACE_OAUTH_REDIRECT_URI=http://127.0.0.1:7778/oauth/callback

# Argo CD Microsoft/Entra SSO through the official argocd CLI. Run
# scripts\Initialize-ItOpsAuth.ps1 once; Start-ItOps also refreshes it as needed.
# Argo CD RBAC must grant only get permissions.
ARGOCD_AUTH_MODE=cli-sso
ARGOCD_BASE_URL=https://YOUR_ARGOCD_HOST
ARGOCD_CLI_PATH=argocd.exe
ARGOCD_CLI_SERVER=YOUR_ARGOCD_HOST
ARGOCD_CLI_CONTEXT=itops-readonly
ARGOCD_CLI_CONFIG=
ARGOCD_CLI_GRPC_WEB=false
ARGOCD_CLI_GRPC_WEB_ROOT_PATH=
ARGOCD_CLI_TIMEOUT_MS=30000
# Token fallback only when ARGOCD_AUTH_MODE=token.
ARGOCD_TOKEN=
ARGOCD_PROJECT_ALLOWLIST=*
ARGOCD_APPLICATION_ALLOWLIST=*

# Source-code investigation. Paths matching the built-in secret denylist are always blocked.
SOURCE_CODE_MAX_FILE_BYTES=250000
# Optional comma-separated patterns that extend (never replace) the built-in denylist.
SOURCE_CODE_PATH_DENYLIST=

# Bitbucket Cloud. Bearer is for repository/workspace access tokens; basic uses email + API token.
# Use repository read, pull-request read, and pipeline read permissions only.
BITBUCKET_BASE_URL=https://api.bitbucket.org
BITBUCKET_AUTH_MODE=bearer
BITBUCKET_EMAIL=
BITBUCKET_API_TOKEN=CHANGE_ME
BITBUCKET_REPOSITORY_ALLOWLIST=YOUR_WORKSPACE/YOUR_REPOSITORY
BITBUCKET_HEALTH_REPOSITORY=YOUR_WORKSPACE/YOUR_REPOSITORY

# GitLab SaaS or self-managed. Use a token limited to read_api/read_repository and allowlisted projects.
GITLAB_BASE_URL=https://gitlab.example.com
GITLAB_AUTH_MODE=private-token
GITLAB_TOKEN=CHANGE_ME
GITLAB_PROJECT_ALLOWLIST=YOUR_GROUP/YOUR_PROJECT
GITLAB_HEALTH_PROJECT=YOUR_GROUP/YOUR_PROJECT
