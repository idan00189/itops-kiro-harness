# Copy this file to config\itops.env, fill values, and keep that file out of source control.
# Use read-only service identities only. Do not add quotes unless the value itself requires them.

# Harness
ITOPS_REPORT_DIR=reports
ITOPS_ARTIFACT_DIR=artifacts/splunk
ITOPS_AUDIT_LOG=audit/mcp-audit.jsonl
ITOPS_HOOK_AUDIT_LOG=audit/kiro-hook-audit.jsonl
ITOPS_MAX_RESULT_BYTES=1000000
ITOPS_MAX_HTTP_RESPONSE_BYTES=5000000
ITOPS_HTTP_TIMEOUT_MS=30000
ITOPS_REDACT_KEYS=access_token,refresh_token,client_secret,user_email,phone,address
# For private enterprise CAs, set a PEM bundle path. Never disable certificate validation.
NODE_EXTRA_CA_CERTS=

# Enable or disable integrations independently
ITOPS_ENABLE_ATLASSIAN=true
ITOPS_ENABLE_SPLUNK=true
ITOPS_ENABLE_SQLSERVER=true
ITOPS_ENABLE_MONGODB=true
ITOPS_ENABLE_DYNATRACE=true
ITOPS_ENABLE_ARGOCD=true
ITOPS_ENABLE_SOURCE_CODE=true
ITOPS_ENABLE_BITBUCKET=true
ITOPS_ENABLE_GITLAB=true

# Jira and Confluence: Cloud basic auth uses email + API token.
# For Data Center PAT, set ATLASSIAN_AUTH_MODE=bearer and adjust paths if necessary.
ATLASSIAN_BASE_URL=https://YOUR_SITE.atlassian.net
ATLASSIAN_AUTH_MODE=basic
ATLASSIAN_EMAIL=CHANGE_ME
ATLASSIAN_API_TOKEN=CHANGE_ME
ATLASSIAN_JIRA_SEARCH_PATH=/rest/api/3/search/jql
ATLASSIAN_CONFLUENCE_SEARCH_PATH=/wiki/rest/api/search
ATLASSIAN_MAX_RESULTS=100

# Splunk management REST API
SPLUNK_BASE_URL=https://YOUR_SPLUNK_HOST:8089
SPLUNK_TOKEN=CHANGE_ME
SPLUNK_AUTH_SCHEME=Bearer
SPLUNK_EXPORT_PATH=/services/search/v2/jobs/export
SPLUNK_MAX_RESULTS=500
SPLUNK_SEARCH_TIMEOUT_MS=60000

# SQL Server Availability Group listener / read-only replica
SQLSERVER_HOST=YOUR_AG_LISTENER
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=YOUR_DATABASE
SQLSERVER_USERNAME=CHANGE_ME
SQLSERVER_PASSWORD=CHANGE_ME
SQLSERVER_ENCRYPT=true
SQLSERVER_TRUST_SERVER_CERTIFICATE=false
SQLSERVER_CONNECT_TIMEOUT_MS=15000
SQLSERVER_QUERY_TIMEOUT_MS=30000
SQLSERVER_MAX_ROWS=500
SQLSERVER_POOL_MAX=4

# MongoDB or Amazon DocumentDB
# URI examples:
# mongodb://readonly-user:password@host:27017/?authSource=admin&readPreference=secondaryPreferred
# mongodb://readonly-user:password@docdb.cluster:27017/?tls=true&replicaSet=rs0&readPreference=secondaryPreferred&retryWrites=false
MONGODB_MODE=mongodb
MONGODB_URI=CHANGE_ME
MONGODB_DATABASE=YOUR_DATABASE
MONGODB_TLS_CA_FILE=
MONGODB_READ_PREFERENCE=secondaryPreferred
MONGODB_COLLECTION_ALLOWLIST=*
MONGODB_CONNECT_TIMEOUT_MS=15000
MONGODB_QUERY_TIMEOUT_MS=30000
MONGODB_MAX_DOCUMENTS=500
MONGODB_POOL_MAX=4

# Dynatrace Environment API v2
DYNATRACE_ENV_URL=https://YOUR_ENV_ID.live.dynatrace.com
DYNATRACE_API_TOKEN=CHANGE_ME

# Dynatrace Grail DQL Query API. Set DYNATRACE_DQL_ENABLED=false for classic-only environments.
DYNATRACE_DQL_ENABLED=true
DYNATRACE_PLATFORM_URL=https://YOUR_ENV_ID.apps.dynatrace.com
# Prefer OAuth client credentials. A short-lived direct bearer token may be supplied in DYNATRACE_PLATFORM_TOKEN instead.
DYNATRACE_PLATFORM_TOKEN=
DYNATRACE_OAUTH_TOKEN_URL=https://sso.dynatrace.com/sso/oauth2/token
DYNATRACE_OAUTH_CLIENT_ID=CHANGE_ME
DYNATRACE_OAUTH_CLIENT_SECRET=CHANGE_ME
DYNATRACE_OAUTH_SCOPES=storage:buckets:read storage:logs:read storage:spans:read storage:events:read storage:metrics:read
DYNATRACE_DQL_TABLE_ALLOWLIST=logs,spans,events,bizevents,metrics,dt.entity.*
DYNATRACE_DQL_MAX_RECORDS=1000
DYNATRACE_DQL_MAX_BYTES=2000000
DYNATRACE_QUERY_TIMEOUT_MS=60000

# Argo CD API token bound to role:readonly or a narrower custom get-only role
ARGOCD_BASE_URL=https://YOUR_ARGOCD_HOST
ARGOCD_TOKEN=CHANGE_ME
ARGOCD_PROJECT_ALLOWLIST=*
ARGOCD_APPLICATION_ALLOWLIST=*

# Source-code investigation. Paths matching the built-in secret denylist are always blocked.
SOURCE_CODE_MAX_FILE_BYTES=250000
# Optional comma-separated patterns that extend (never replace) the built-in denylist.
SOURCE_CODE_PATH_DENYLIST=

# Bitbucket Cloud. Bearer is for repository/workspace access tokens; basic uses email + API token.
# Use repository read, pull-request read, and pipeline read permissions only.
BITBUCKET_BASE_URL=https://api.bitbucket.org
BITBUCKET_AUTH_MODE=bearer
BITBUCKET_EMAIL=
BITBUCKET_API_TOKEN=CHANGE_ME
BITBUCKET_REPOSITORY_ALLOWLIST=YOUR_WORKSPACE/YOUR_REPOSITORY
BITBUCKET_HEALTH_REPOSITORY=YOUR_WORKSPACE/YOUR_REPOSITORY

# GitLab SaaS or self-managed. Use a token limited to read_api/read_repository and allowlisted projects.
GITLAB_BASE_URL=https://gitlab.example.com
GITLAB_AUTH_MODE=private-token
GITLAB_TOKEN=CHANGE_ME
GITLAB_PROJECT_ALLOWLIST=YOUR_GROUP/YOUR_PROJECT
GITLAB_HEALTH_PROJECT=YOUR_GROUP/YOUR_PROJECT
